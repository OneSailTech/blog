---
export interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const {
    title = 'OneSail Tech',
    description = 'OneSail Tech — 分享技术、设计与生活随笔',
    image = '/favicon.webp',
} = Astro.props;

---

<!doctype html>
<html lang="zh-CN">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/webp" href="/favicon.webp" />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="generator" content="1Fan" />

        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:locale" content="zh_CN" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
    </head>
    <body>
        <slot />
        <footer class="site-footer">
            <p>© {new Date().getFullYear()} OneSail Tech. All rights reserved.</p>
            <!-- <p><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">赣ICP备XXXXXXXX号</a></p> -->
        </footer>
    </body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        outline: none;
    }

    html {
        overflow-x: hidden;
        scrollbar-gutter: stable;
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #999; }
    * { scrollbar-width: thin; scrollbar-color: #ccc transparent; }

    html,
    body {
        width: 100%;
        min-height: 100%;
        background-color: #ffffff;
        color: #000000;
        font-family: sans-serif;
    }

    .site-footer {
        text-align: center;
        padding: 2rem 1rem;
        z-index: 10;
    }

    .site-footer p {
        color: #999;
        font-size: 0.75rem;
        margin: 0;
    }

    .site-footer a {
        color: #999;
        text-decoration: none;
        transition: color 0.2s;
    }

    .site-footer a:hover {
        color: #2563eb;
    }
</style>
